# RIICA — variáveis de ambiente do frontend (Vite)
# Copie para .env e ajuste conforme o ambiente.

# Supabase local. Rode `npx supabase status` para ver a Publishable key.
# A Publishable key (sb_publishable_...) é usada como chave pública do frontend.
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=sb_publishable_ACJWlzQHlZjBrEguHvfOxg_3BJgxAaH

# Lado Node (dev) — usado pelo middleware de envio de e-mail (Mailpit).
# Rode `npx supabase status` para a Secret key. NUNCA commitar a real.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx
MAILPIT_SMTP_HOST=127.0.0.1
MAILPIT_SMTP_PORT=54325
